@mcp.tool()
async def build(
    workspace: str = Field(description="Absolute path to the .xcworkspace to build"),
    scheme: Optional[str] = Field(default=None, description="Build scheme (default: from .env APP_SCHEME)"),
    simulator: Optional[str] = Field(default=None, description="Simulator UDID for -destination"),
) -> str:
    """Build the iOS app for simulator. Returns success or structured error messages.
    Workspace is required — no implicit fallback. Uses worktree-aware DerivedData isolation automatically."""
    success, message = await _build_app(workspace, scheme, simulator)
    return message


@mcp.tool()
async def build_device(
    workspace: str = Field(description="Absolute path to the .xcworkspace to build"),
    scheme: Optional[str] = Field(default=None, description="Build scheme (default: from .env APP_SCHEME)"),
    device: Optional[str] = Field(default=None, description="Device xcodebuild ID (default: from .env DEVICE_XCODEBUILD_ID)"),
    install: bool = Field(default=True, description="Install on device after building"),
    launch: bool = Field(default=True, description="Launch app after installing"),
) -> str:
    """Build the iOS app for a physical device, optionally install and launch.
    NO dylib injection — plain device build for testing on real hardware.
    Workspace is required — no implicit fallback. Uses worktree-aware DerivedData isolation."""
    cfg = get_config()
    devicectl_uuid = cfg["device_devicectl_uuid"]

    if not devicectl_uuid and (install or launch):
        return "No device devicectl UUID configured. Set DEVICE_DEVICECTL_UUID in pepper/.env"

    # Verify device is connected before building (fail fast)
    if install or launch:
        connected, msg = await _verify_device_connected(devicectl_uuid)
        if not connected:
            return msg

    # Build
    success, build_msg = await _build_app_device(workspace, scheme, device)
    if not success:
        return build_msg

    parts = [build_msg]

    if install:
        app_path = _find_built_app(workspace, platform="iphoneos")
        if not app_path:
            return f"{build_msg}\n\nBuild succeeded but could not find .app in DerivedData (Debug-iphoneos/)"
        ok, msg = await _install_on_device(devicectl_uuid, app_path)
        parts.append(msg)
        if not ok:
            return "\n".join(parts)

    if launch and install:
        bid = cfg["bundle_id"]
        if not bid:
            parts.append("No bundle ID configured — skipping launch")
        else:
            ok, msg = await _launch_on_device(devicectl_uuid, bid)
            parts.append(msg)

    return "\n".join(parts)


@mcp.tool()
async def iterate(
    workspace: str = Field(description="Absolute path to the .xcworkspace to build"),
    scheme: Optional[str] = Field(default=None, description="Build scheme (default: from .env APP_SCHEME)"),
    simulator: Optional[str] = Field(default=None, description="Simulator UDID"),
    bundle_id: Optional[str] = Field(default=None, description="App bundle ID (default: from .env APP_BUNDLE_ID)"),
) -> str:
    """The complete edit→build→deploy→verify loop in ONE call.
    Builds the app, installs it on the simulator, launches with Pepper injected,
    and returns the screen state. Use this after editing code to see your changes.
    Workspace is required — no implicit fallback."""
    # Resolve sim first
    try:
        sim = _resolve_simulator(simulator)
    except RuntimeError as e:
        return str(e)

    # Build
    success, build_msg = await _build_app(workspace, scheme, sim)
    if not success:
        return build_msg

    # Find built .app
    app_path = _find_built_app(workspace)

    # Deploy
    deploy_msg = await _deploy_app(sim, send_fn=send_command, bundle_id=bundle_id, install_path=app_path)
    return f"{build_msg}\n\n{deploy_msg}"


@mcp.tool()
async def deploy(
    simulator: Optional[str] = Field(default=None, description="Simulator UDID"),
    bundle_id: Optional[str] = Field(default=None, description="App bundle ID (default: from .env)"),
    dylib_path: Optional[str] = Field(default=None, description="Path to Pepper dylib (default: from .env)"),
    skip_privacy: bool = Field(default=False, description="Skip auto-granting privacy permissions (photos, camera, microphone, contacts, calendar, location)"),
) -> str:
    """Terminate and relaunch the app with Pepper dylib injection.
    Does NOT rebuild — use `build` or `iterate` for that.
    Use this when you just need to restart the app (e.g. after a crash).
    By default, grants common privacy permissions before launch (opt out with skip_privacy=true)."""
    try:
        sim = _resolve_simulator(simulator)
    except RuntimeError as e:
        return str(e)
    return await _deploy_app(sim, send_fn=send_command, bundle_id=bundle_id, dylib_path=dylib_path, skip_privacy=skip_privacy)


