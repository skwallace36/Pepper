def try_parse_json(value):
    """Try to parse a string as JSON for proper typing (bool, int, dict, list).
    Returns the parsed value on success, or the original string on failure."""
    if value is None:
        return None
    try:
        return json.loads(value)
    except (json.JSONDecodeError, TypeError):
        return value


def require_parse_json(value, field_name="value"):
    """Parse a string as JSON, raising ValueError with a descriptive message on failure."""
    try:
        return json.loads(value)
    except json.JSONDecodeError as e:
        raise ValueError(f"{field_name} must be valid JSON: {e}")


# ---------------------------------------------------------------------------
# WebSocket command sender
# ---------------------------------------------------------------------------

async def send_command(port: int, cmd: str, params: Optional[dict] = None, timeout: float = 10) -> dict:
    """Send a command to Pepper's WebSocket server and return the response.

    Wraps pepper_websocket.send_command with MCP-appropriate error handling
    (returns error dicts instead of raising).
    """
    msg = make_command(cmd, params)
    try:
        return await ws_send_command("localhost", port, msg, timeout=timeout)
    except asyncio.TimeoutError:
        return {"status": "error", "error": f"Command timed out after {timeout}s"}
    except ConnectionRefusedError:
        return {"status": "error", "error": f"Connection refused on port {port}. Is Pepper running?"}
    except CrashError as e:
        return {
            "status": "error",
            "error": f"{e} Crash log will be auto-attached below."
        }
    except Exception as e:
        err_str = str(e)
        if "close frame" in err_str or "connection" in err_str.lower():
            return {
                "status": "error",
                "error": f"APP CRASHED. The '{cmd}' command likely crashed the app ({err_str}). "
                         f"Investigate the crash before retrying."
            }
        return {"status": "error", "error": err_str}


async def resolve_and_send(simulator: Optional[str], cmd: str, params: Optional[dict] = None, timeout: float = 10) -> str:
    """Resolve port and send command. Returns JSON string. Auto-appends crash info on APP CRASHED."""
    try:
        udid, port = discover_simulator(simulator)
    except RuntimeError as e:
        return json.dumps({"status": "error", "error": str(e)}, indent=2)
    resp = await send_command(port, cmd, params, timeout)
    result = json.dumps(resp, indent=2)
    # Auto-fetch crash info when app crashes
    error = resp.get("error", "")
    if "APP CRASHED" in error:
        crash_info = await fetch_crash_info(udid)
        if crash_info:
            result += crash_info
    return result


async def act_and_look(simulator: Optional[str], cmd: str, params: Optional[dict] = None, timeout: float = 10) -> str:
    """Thin wrapper that passes the local send_command to mcp_telemetry.act_and_look."""
    return await _act_and_look(simulator, cmd, params, timeout, send_fn=send_command)


