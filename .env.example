# Pepper .env — app-specific build config (gitignored)
# Copy to .env and fill in your paths.

# Xcode scheme to build
APP_SCHEME=YourApp

# App bundle ID
APP_BUNDLE_ID=com.example.yourapp

# Adapter type (e.g. "fi" for Fi app, or omit for generic)
# APP_ADAPTER_TYPE=fi

# Path to adapter repo (Swift files compiled alongside pepper dylib)
# ADAPTER_PATH=/path/to/Fi-Pepper-Adaptor

# App repo root (for adapter tools — localization, codegen, etc.)
# Tools config lives at ~/.pepper/tools/{adapter_type}.json
# APP_REPO=/path/to/your/ios/repo

# (Optional) Override dylib path — defaults to pepper/build/Pepper.framework/Pepper
# APP_DYLIB_PATH=/path/to/Pepper.framework/Pepper

# (Optional) Python 3.10+ for MCP server — set PEPPER_PYTHON env var in your shell
# export PEPPER_PYTHON=/opt/homebrew/bin/python3.11
